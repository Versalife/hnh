---
import PostLayout from '../../layouts/PostLayout.astro';
import { getCollection, render } from 'astro:content';
import readingTime from 'reading-time';

export async function getStaticPaths() {
  const published = (await getCollection('writing', ({ data }) => !data.draft))
    .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());

  return published.map(post => {
    const idx = published.findIndex(p => p.id === post.id);
    return {
      params: { slug: post.id },
      props: {
        post,
        prev: idx > 0 ? { slug: published[idx - 1].id, title: published[idx - 1].data.title } : null,
        next: idx < published.length - 1 ? { slug: published[idx + 1].id, title: published[idx + 1].data.title } : null,
      },
    };
  });
}

const { post, prev, next } = Astro.props;
const { Content, headings } = await render(post);
const rt = readingTime(post.body);
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  readingTime={rt?.text}
  headings={headings}
  prev={prev}
  next={next}
  citationKey={post.data.citationKey}
  citationUrl={post.data.citationUrl}
>
  <Content />
</PostLayout>
