{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "type": {
      "type": "string",
      "enum": [
        "sketch",
        "snippet"
      ]
    },
    "attribution": {
      "type": "string"
    },
    "attributionUrl": {
      "type": "string",
      "format": "uri"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "refs": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "date",
    "type"
  ]
}