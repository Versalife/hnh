---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allSketches = (await getCollection('sketches', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const rendered = await Promise.all(
  allSketches.map(async s => {
    const { Content } = await s.render();
    return { s, Content };
  })
);

const slugToTitle = new Map(allSketches.map(s => [s.slug, s.data.title]));
---

<BaseLayout title="Sketches & Snippets" description="Rough ideas and passing thoughts, arranged chronologically.">
  <main class="sketches-main">
    <h1 style="font-size: 1.5rem; margin-bottom: 0.25rem;">Sketches & Snippets</h1>
    <p style="color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 2rem;">
      Rough ideas and passing thoughts, arranged as they occurred.
    </p>

    <ol class="sketch-list">
      {rendered.map(({ s, Content }) => {
        const refs = s.data.refs ?? [];
        const hasFooter = !!s.data.attribution || refs.length > 0;
        return (
          <li id={`sketch-${s.slug}`} class="sketch-item">
            <details class="sketch-details">
              <summary class="sketch-summary">
                <span class="sketch-date">
                  {s.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
                </span>
                <span class="sketch-title">{s.data.title}</span>
                <span class={`sketch-type-badge sketch-type-${s.data.type}`}>{s.data.type}</span>
              </summary>
              <div class="sketch-body">
                <Content />
                {hasFooter && (
                  <div class="sketch-footer">
                    {s.data.attribution && (
                      <p class="sketch-attribution">
                        &#x2014;{' '}
                        {s.data.attributionUrl
                          ? <a href={s.data.attributionUrl} target="_blank" rel="noopener noreferrer">{s.data.attribution}</a>
                          : s.data.attribution}
                      </p>
                    )}
                    {refs.length > 0 && (
                      <p class="sketch-refs">
                        cf.{' '}
                        {refs.map((r, i) => (
                          <span>
                            <a href={`#sketch-${r}`}>{slugToTitle.get(r) ?? r}</a>
                            {i < refs.length - 1 ? ', ' : ''}
                          </span>
                        ))}
                      </p>
                    )}
                  </div>
                )}
              </div>
            </details>
          </li>
        );
      })}
    </ol>
  </main>
</BaseLayout>

<style>
  .sketches-main {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }

  /* ── List container ── */
  .sketch-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sketch-item {
    border-bottom: 1px solid var(--color-border);
  }

  .sketch-item:first-child {
    border-top: 1px solid var(--color-border);
  }

  /* ── Summary row ── */
  .sketch-summary {
    display: grid;
    grid-template-columns: 7.5rem 1fr auto;
    gap: 0 1.5rem;
    align-items: center;
    padding: 0.65rem 0;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  /* Remove browser default disclosure triangle */
  .sketch-summary::-webkit-details-marker { display: none; }
  .sketch-summary::marker { content: ''; }

  .sketch-date {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .sketch-title {
    color: var(--color-text);
    font-size: 1rem;
  }

  /* Subtle expand indicator via rotating chevron */
  .sketch-title::before {
    content: '›';
    display: inline-block;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-right: 0.35rem;
    transition: transform 0.15s ease;
    line-height: 1;
  }

  .sketch-details[open] .sketch-title::before {
    transform: rotate(90deg);
  }

  .sketch-summary:hover .sketch-title {
    color: var(--color-accent);
  }

  .sketch-summary:hover .sketch-title::before {
    color: var(--color-accent);
  }

  /* ── Expanded body ── */
  .sketch-body {
    padding: 0.75rem 0 1.5rem 9rem; /* align with title column: 7.5rem + 1.5rem gap */
    font-size: 0.95rem;
    line-height: 1.7;
  }

  /* ── Footer (attribution + cf. refs) ── */
  .sketch-footer {
    margin-top: 1rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .sketch-footer p {
    margin: 0;
  }

  .sketch-footer p + p {
    margin-top: 0.2rem;
  }

  /* Flatten sidenotes inside sketch body */
  :global(.sketch-body .sidenote) {
    float: none;
    clear: none;
    display: block;
    width: auto;
    margin: 0.5rem 0 1rem;
    border-left: 2px solid var(--color-border);
    padding-left: 0.75rem;
    font-size: 0.82rem;
    color: var(--color-text-muted);
  }

  /* ── Responsive ── */
  @media (max-width: 760px) {
    .sketches-main {
      padding: 2rem 1rem;
    }

    .sketch-summary {
      grid-template-columns: 1fr auto;
      row-gap: 0.1rem;
    }

    .sketch-date {
      grid-column: 1;
      grid-row: 2;
      font-size: 0.75rem;
    }

    .sketch-title {
      grid-column: 1;
      grid-row: 1;
    }

    .sketch-type-badge {
      grid-column: 2;
      grid-row: 1;
      align-self: start;
    }

    .sketch-body {
      padding-left: 0;
    }
  }
</style>

<script>
  function openSketchFromHash(hash: string) {
    if (!hash.startsWith('#sketch-')) return;
    const li = document.getElementById(hash.slice(1));
    if (!li) return;
    const det = li.querySelector('details') as HTMLDetailsElement | null;
    if (det && !det.open) {
      det.open = true;
      setTimeout(() => li.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
    }
  }

  const allDetails = Array.from(document.querySelectorAll<HTMLDetailsElement>('.sketch-details'));

  allDetails.forEach(det => {
    det.addEventListener('toggle', () => {
      if (det.open) {
        allDetails.forEach(other => { if (other !== det) other.open = false; });
        requestAnimationFrame(() =>
          det.scrollIntoView({ behavior: 'smooth', block: 'nearest' })
        );
      }
    });
  });

  openSketchFromHash(location.hash);
  window.addEventListener('hashchange', () => openSketchFromHash(location.hash));
</script>
